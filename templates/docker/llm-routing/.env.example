# =============================================================================
# DuarteOS - Variáveis de Ambiente para LiteLLM Proxy
# =============================================================================
# Copie este arquivo para .env e preencha com suas chaves:
#   cp .env.example .env
# =============================================================================

# Chave da API DeepSeek (usado para roteamento de Sonnet e Haiku)
# Obtenha em: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Chave da API OpenRouter (usado como fallback)
# Obtenha em: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Chave da API Anthropic (usado para Opus direto)
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=
