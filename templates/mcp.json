{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "env": {
        "DEFAULT_MINIMUM_TOKENS": "10000"
      }
    },
    "exa": {
      "command": "npx",
      "args": [
        "-y",
        "exa-mcp-server",
        "--tools=web_search_exa,get_code_context_exa,company_research_exa,crawling_exa"
      ]
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    },
    "apify": {
      "command": "npx",
      "args": [
        "-y",
        "@apify/actors-mcp-server",
        "--tools=actors,apify/web-scraper,apify/rag-web-browser"
      ]
    },
    "youtube-transcript": {
      "command": "npx",
      "args": ["-y", "@kimtaeyoon83/mcp-server-youtube-transcript"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"]
    },
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.supabase.com/mcp"
      ]
    },
    "n8n": {
      "command": "npx",
      "args": ["-y", "n8n-mcp"],
      "env": {
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true"
      }
    },
    "google-workspace": {
      "command": "uvx",
      "args": ["workspace-mcp", "--single-user"]
    },
    "obsidian": {
      "command": "npx",
      "args": [
        "-y",
        "@mauricio.wolff/mcp-obsidian@latest"
      ]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "data-analyzer": {
      "command": "uv",
      "args": ["run", "--with", "fastmcp<3", "--with", "pandas,numpy,matplotlib,seaborn", "python", ".claude/mcp-servers/data-analyzer/server.py"]
    },
    "web-scraper": {
      "command": "uv",
      "args": ["run", "--with", "fastmcp<3", "--with", "requests,beautifulsoup4,lxml", "python", ".claude/mcp-servers/web-scraper/server.py"]
    },
    "automation": {
      "command": "uv",
      "args": ["run", "--with", "fastmcp<3", "--with", "watchdog", "python", ".claude/mcp-servers/automation/server.py"]
    },
    "input-analyzer": {
      "command": "uv",
      "args": ["run", "--with", "fastmcp<3", "--with", "requests,beautifulsoup4,lxml,pyyaml", "python", ".claude/mcp-servers/input-analyzer/server.py"]
    },
    "memory-graph": {
      "command": "uv",
      "args": ["run", "--with", "fastmcp<3", "python", ".claude/mcp-servers/memory-graph/server.py"]
    },
    "tool-forge": {
      "command": "uv",
      "args": ["run", "--with", "fastmcp<3", "python", ".claude/mcp-servers/tool-forge/server.py"]
    },
    "redis-session": {
      "command": "uv",
      "args": ["run", "--with", "fastmcp<3", "--with", "redis", "python", ".claude/mcp-servers/redis-session/server.py"]
    },
    "redis-task-manager": {
      "command": "uv",
      "args": ["run", "--with", "fastmcp<3", "--with", "redis", "python", ".claude/mcp-servers/redis-task-manager/server.py"]
    },
    "e2b-sandbox": {
      "command": "npx",
      "args": ["-y", "@e2b/mcp-server"]
    }
  }
}
